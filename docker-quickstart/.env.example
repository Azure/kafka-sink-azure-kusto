# Environment variables for the Kusto Sink Connector Docker quickstart.
# Copy this file to .env and fill in the values.

# =============================================================================
# Azure Data Explorer - Kusto Configuration
# =============================================================================

# Kusto cluster ingestion URL (used by the Kafka Sink Connector)
KUSTO_INGEST_URL="https://ingest-CLUSTER.REGION.kusto.windows.net"

# Kusto cluster engine/query URL (used by OTEL exporter and Grafana)
KUSTO_ENGINE_URL="https://CLUSTER.REGION.kusto.windows.net"

# Target database name (used for both data and metrics tables)
KUSTO_DATABASE="your-database"

# Target table name for Kafka data - create first using connector-config/create-table.kql
KUSTO_TABLE="KafkaSinkQuickstart"

# OTEL Metrics table - create first using connector-config/create-table.kql
KUSTO_METRICS_TABLE="OTELMetrics"

# =============================================================================
# Authentication - Azure AD Application (shared by all components)
# =============================================================================

# Azure AD Application Service Principal ID
KUSTO_AUTH_APPID="your-app-id"

# Azure AD Application Secret
KUSTO_AUTH_APPKEY="your-app-key"

# Azure AD Tenant/Authority ID
KUSTO_AUTH_AUTHORITY="your-tenant-id"

# =============================================================================
# Kafka Topic
# =============================================================================

# The Kafka topic to consume from
KAFKA_TOPIC="kusto-sink-topic"
