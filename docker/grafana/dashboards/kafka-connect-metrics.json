    {
      "type": "timeseries",
      "title": "Records Written",
      "description": "Total records written to Kusto over time",
      "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
          "rawMode": true,
          "resultFormat": "time_series",
          "query": "OTELMetrics\n| where MetricName == 'kusto_sink_recordswritten_total'\n| where $__timeFilter(Timestamp)\n| project Timestamp, MetricValue\n| order by Timestamp asc",
          "refId": "A"
        }
      ]
