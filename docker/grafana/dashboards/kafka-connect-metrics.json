          "rawMode": true,
          "resultFormat": "table",
          "query": "OTELMetrics\n| where MetricName startswith 'kusto_sink_'\n| summarize LatestValue=arg_max(Timestamp, MetricValue) by MetricName\n| project MetricName, LatestValue, MetricValue\n| order by MetricName asc",
          "refId": "A"
        }
      ]
    },
