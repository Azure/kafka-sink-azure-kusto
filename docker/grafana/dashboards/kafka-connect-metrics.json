          "rawMode": true,
          "resultFormat": "time_series",
          "query": "OTELMetrics\n| where MetricName in ('kusto_sink_ingestionattempts_total', 'kusto_sink_ingestionsuccesses_total', 'kusto_sink_ingestionfailures_total')\n| where $__timeFilter(Timestamp)\n| extend Series = case(\n    MetricName == 'kusto_sink_ingestionattempts_total', 'IngestionAttempts',\n    MetricName == 'kusto_sink_ingestionsuccesses_total', 'IngestionSuccesses',\n    MetricName == 'kusto_sink_ingestionfailures_total', 'IngestionFailures',\n    MetricName)\n| project Timestamp, MetricValue, Series\n| order by Timestamp asc",
          "refId": "A"
        }
      ]
    },
